{
  "type": "record",
  "name": "OrderEvent",
  "namespace": "net.javamicros.avro",
  "fields": [
    { "name": "orderId", "type": "string" },
    { "name": "message", "type": "string" },
    {
      "name": "status",
      "type": {
        "type": "enum",
        "name": "OrderStatus",
        "symbols": ["CREATED", "CONFIRMED", "REJECTED"]
      }
    },
    {
      "name": "createdAt",
      "type": {
        "type": "long",
        "logicalType": "timestamp-millis"
      }
    }
  ]
}